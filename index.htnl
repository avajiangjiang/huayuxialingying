<button class="back-to-top" id="backToTop">↑</button>
<script>
  const navToggle = document.getElementById('navToggle');
n  const navLinks = document.getElementById('navLinks');
n  navToggle.addEventListener('click', () => { navLinks.classList.toggle('show'); });
n  document.querySelectorAll('.nav-links a').forEach(link => {
n    link.addEventListener('click', () => { navLinks.classList.remove('show'); });
n  });
n  document.querySelectorAll('.faq-item').forEach(item => {
n    item.querySelector('.faq-q').addEventListener('click', () => { item.classList.toggle('open'); });
n  });
n  const observer = new IntersectionObserver((entries) => {
n    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
n  }, { threshold: 0.1 });
n  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
n  const backToTop = document.getElementById('backToTop');
n  window.addEventListener('scroll', () => { backToTop.classList.toggle('show', window.scrollY > 500); });
n  backToTop.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); });
n  const sections = document.querySelectorAll('section[id], div[id]');
n  const navItems = document.querySelectorAll('.nav-links a');
n  window.addEventListener('scroll', () => {
n    let current = '';
n    sections.forEach(section => { if (scrollY >= section.offsetTop - 80) current = section.getAttribute('id'); });
n    navItems.forEach(link => { link.classList.toggle('active', link.getAttribute('href') === '#' + current); });
n  });
n</script>
</body>
